# Настройки доступа к хостингу hoster.by для deploy.sh.
# Скопируй этот файл в .env.deploy и заполни своими данными из панели ISPmanager.
# .env.deploy в .gitignore — пароль НЕ попадёт в git.

# Протокол: sftp (безопаснее, нужен SSH/SFTP-доступ) или ftp (есть на любом тарифе)
FTP_PROTOCOL=ftp

# Хост из панели hoster.by. Обычно это ftp.ТВОЙ-ДОМЕН.by, либо IP сервера,
# либо что-то вида serverNN.hoster.by — точное значение есть в письме/панели.
FTP_HOST=ftp.example.by

# Порт можно не указывать (ftp=21, sftp=22 по умолчанию). Заполни если хостер дал другой.
FTP_PORT=

# Логин и пароль FTP/SFTP-пользователя из панели
FTP_USER=your_login
FTP_PASS=your_password

# Папка на сервере, куда залить сайт (корень сайта / document root).
# На hoster.by обычно одно из: /public_html  или  /www/ТВОЙ-ДОМЕН.by  или  /domains/ТВОЙ-ДОМЕН.by/public_html
# Точный путь видно в File Manager панели. Должен заканчиваться на каталог, где лежит index.html сайта.
REMOTE_DIR=/public_html
